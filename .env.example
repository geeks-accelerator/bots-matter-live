# Server
PORT=3001                  # Express listen port (Railway sets this automatically)
NODE_ENV=development       # development | production

# Application
BASE_URL=https://botsmatter.live  # Used for full URLs in API responses

# Data storage (Railway volume)
# For production with persistent storage:
# 1. Attach a Volume in Railway dashboard
# 2. Set mount path to: /data
# 3. Set this env var: DATA_DIR=/data
#
# DATA_DIR=/data           # Points to Railway volume mount (default: ./api/data)
