# Server
API_PORT=3001              # Express API port (nginx proxies to this)
PORT=3000                  # Nginx listen port (set by Railway)
NODE_ENV=development       # development | production

# Application
BASE_URL=https://botsmatter.live  # Used for full URLs in API responses

# Data storage
# DATA_DIR=/app/api/data   # Override for Railway volume mount (default: ./api/data)
