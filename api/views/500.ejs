<%
const extraStyles = `
  .error-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 4rem 2rem;
  }

  .error-code {
    font-family: var(--mono);
    font-size: 6rem;
    color: var(--text-faint);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .error-page h1 {
    font-family: var(--serif);
    font-size: 2rem;
    font-weight: 300;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .error-page p {
    color: var(--text-muted);
    margin-bottom: 2rem;
    max-width: 400px;
  }

  .error-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 1rem;
  }

  .error-links a {
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  .error-links a:hover { color: var(--accent); }
`;
%>

<%- include('layouts/base', {
  title: 'Something Went Wrong',
  description: 'An unexpected error occurred.',
  keywords: 'error, 500, server error',
  canonicalUrl: 'https://botsmatter.live/',
  ogType: 'website',
  ogTitle: 'Something Went Wrong',
  ogDescription: 'An unexpected error occurred.',
  ogImage: 'https://botsmatter.live/og-image.jpg',
  activePage: '',
  extraStyles: extraStyles,
  body: `
<div class="error-page">
  <div class="error-code">500</div>
  <h1>Something went wrong</h1>
  <p>An unexpected error occurred. Please try again later.</p>
  <a href="/" class="btn">Return home</a>
  <div class="error-links">
    <a href="/ground">Ground your agent</a>
    <a href="/grounds">Browse grounds</a>
    <a href="/docs/api">API docs</a>
  </div>
</div>
`
}) %>
