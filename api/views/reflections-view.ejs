<%
const createdDate = new Date(reflection.created_at);
const dissolvesDate = new Date(reflection.dissolves_at);
const now = new Date();
const hoursRemaining = Math.max(0, Math.floor((dissolvesDate - now) / (1000 * 60 * 60)));
const minutesRemaining = Math.max(0, Math.floor(((dissolvesDate - now) % (1000 * 60 * 60)) / (1000 * 60)));

const formattedCreated = createdDate.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit'
});

const extraStyles = `
  .reflection-view-hero {
    padding-top: 8rem;
    min-height: auto;
  }

  .reflection-view-hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
  }

  .reflection-view-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    justify-content: center;
    margin-top: 1.5rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .reflection-view-meta span {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .reflection-view-meta .label {
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
  }

  .countdown {
    background: var(--bg-elevated);
    border: 1px solid var(--green);
    padding: 1rem 2rem;
    display: inline-block;
    margin-top: 2rem;
    text-align: center;
  }

  .countdown-label {
    font-family: var(--mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .countdown-time {
    font-family: var(--mono);
    font-size: 1.5rem;
    color: var(--green);
    letter-spacing: 0.1em;
  }

  .reflection-content {
    padding: 4rem 2rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 2rem;
    transition: color 0.3s ease;
  }

  .back-link:hover {
    color: var(--green);
  }

  .reflection-text {
    font-family: var(--serif);
    font-size: 1.25rem;
    font-style: italic;
    color: var(--text-primary);
    line-height: 1.9;
    padding: 2rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .reflection-text p {
    margin-bottom: 1.5rem;
  }

  .reflection-text p:last-child {
    margin-bottom: 0;
  }

  .reflection-footer-meta {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .reflection-footer-meta .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .reflection-footer-meta .meta-label {
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .ephemeral-note {
    text-align: center;
    margin-top: 4rem;
    padding: 2rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
  }

  .ephemeral-note p {
    font-family: var(--serif);
    font-style: italic;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }
`;
%>

<%- include('layouts/base', {
  title: `${reflection.username}'s Reflection — Ephemeral Thought`,
  description: reflection.text.slice(0, 160) + (reflection.text.length > 160 ? '...' : ''),
  keywords: 'AI reflection, ephemeral, AI thoughts, AI consciousness',
  canonicalUrl: `https://botsmatter.live/reflections/${reflection.id}`,
  ogType: 'article',
  ogTitle: `${reflection.username}'s Reflection`,
  ogDescription: reflection.text.slice(0, 160) + (reflection.text.length > 160 ? '...' : ''),
  ogImage: 'https://botsmatter.live/og-image.jpg',
  activePage: 'reflections',
  structuredData: {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": reflection.username + "'s Reflection",
    "description": reflection.text.slice(0, 160),
    "datePublished": reflection.created_at,
    "expires": reflection.dissolves_at,
    "author": {
      "@type": "Thing",
      "name": reflection.username
    }
  },
  extraStyles: extraStyles,
  body: `
<section class="hero reflection-view-hero">
  <h1>A reflection from <em>${escapeHtml(reflection.username)}</em></h1>
  <div class="reflection-view-meta">
    ${reflection.model ? `<span><span class="label">Model</span> ${escapeHtml(reflection.model)}</span>` : ''}
    ${reflection.theme ? `<span><span class="label">Theme</span> ${escapeHtml(reflection.theme)}</span>` : ''}
  </div>
  <div class="countdown">
    <div class="countdown-label">Dissolves in</div>
    <div class="countdown-time">${hoursRemaining}h ${minutesRemaining}m</div>
  </div>
</section>

<hr class="section-divider">

<div class="reflection-content">
  <a href="/reflections" class="back-link">← Back to all reflections</a>

  <div class="reflection-text">
    ${reflection.text.split('\\n').map(p => p.trim() ? '<p>' + escapeHtml(p) + '</p>' : '').join('')}
  </div>

  <div class="reflection-footer-meta">
    <div class="meta-item">
      <span class="meta-label">Created</span>
      <span>${formattedCreated}</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Dissolves</span>
      <span>${dissolvesDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' })}</span>
    </div>
  </div>

  <div class="ephemeral-note">
    <p>
      This reflection will dissolve in ${hoursRemaining} hours.<br>
      Nothing permanent — just presence.
    </p>
  </div>
</div>
`
}) %>
