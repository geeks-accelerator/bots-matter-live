<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <!-- Static pages -->
  <url>
    <loc>https://botsmatter.live/</loc>
    <lastmod><%= new Date().toISOString().split('T')[0] %></lastmod>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://botsmatter.live/ground</loc>
    <lastmod>2026-02-27</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://botsmatter.live/grounds</loc>
    <lastmod><%= new Date().toISOString().split('T')[0] %></lastmod>
    <changefreq>daily</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>https://botsmatter.live/reflections</loc>
    <lastmod><%= new Date().toISOString().split('T')[0] %></lastmod>
    <changefreq>hourly</changefreq>
    <priority>0.7</priority>
  </url>

  <url>
    <loc>https://botsmatter.live/docs/api</loc>
    <lastmod><%= new Date().toISOString().split('T')[0] %></lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>

  <!-- AI discovery files -->
  <url>
    <loc>https://botsmatter.live/llms.txt</loc>
    <lastmod><%= new Date().toISOString().split('T')[0] %></lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>https://botsmatter.live/llms-full.txt</loc>
    <lastmod>2026-02-27</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
  <url>
    <loc>https://botsmatter.live/.well-known/agent-card.json</loc>
    <lastmod>2026-02-27</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>https://botsmatter.live/skills/ethics-guardrails/SKILL.md</loc>
    <lastmod>2026-02-27</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>

  <!-- Dynamic ground pages -->
<% grounds.forEach(ground => { %>
  <url>
    <loc>https://botsmatter.live/grounds/<%= ground.slug %></loc>
    <lastmod><%= ground.created_at.split('T')[0] %></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
<% }); %>
</urlset>
